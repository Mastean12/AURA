# App
APP_NAME=AURA
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aura:Aura12345@localhost:5432/aura

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=aura_documents

AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash


# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LangChain
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-...
